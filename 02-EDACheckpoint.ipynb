  "import pandas as pd\n",
  "import numpy as np\n",
  "import matplotlib.pyplot as plt\n",
  "\n",
  "path = \"/home/l2deng/Project/Group128_WI26/data/02-processed/HMS_2024-25_cleaned.csv\"\n",
  "df = pd.read_csv(path)\n",
  "\n",
  "print(\"Loaded:\", path)\n",
  "display(df.head())\n",
  "\n",
  "print(\"Rows:\", df.shape[0])\n",
  "print(\"Columns:\", df.shape[1])\n",
  "\n",
  "# Focus EDA on PHQ9 and GAD7\n",
  "df_clean = df.dropna(subset=[\"PHQ9\",\"GAD7\"]).copy()\n",
  "\n",
  "df_clean[\"depression_positive\"] = df_clean[\"PHQ9\"] >= 10\n",
  "df_clean[\"anxiety_positive\"] = df_clean[\"GAD7\"] >= 10\n",
  "\n",
  "print(\"Depression prevalence (%):\", round(df_clean[\"depression_positive\"].mean()*100,2))\n",
  "print(\"Anxiety prevalence (%):\", round(df_clean[\"anxiety_positive\"].mean()*100,2))\n",
  "\n",
  "fig,axes = plt.subplots(1,2,figsize=(12,4))\n",
  "\n",
  "axes[0].hist(df_clean[\"PHQ9\"],bins=20,edgecolor=\"black\")\n",
  "axes[0].axvline(10,linestyle=\"--\")\n",
  "axes[0].set_title(\"PHQ9 Distribution\")\n",
  "\n",
  "axes[1].hist(df_clean[\"GAD7\"],bins=20,edgecolor=\"black\")\n",
  "axes[1].axvline(10,linestyle=\"--\")\n",
  "axes[1].set_title(\"GAD7 Distribution\")\n",
  "\n",
  "plt.show()\n"
 ]
}
